---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { readdir } from "node:fs/promises";
import { join } from "node:path";

type HtmlEntry = {
  filename: string;
  title: string;
};

const publicDir = join(process.cwd(), "public");
const dirEntries = await readdir(publicDir, { withFileTypes: true });
const htmlEntries: HtmlEntry[] = dirEntries
  .filter((entry) => entry.isFile() && entry.name.toLowerCase().endsWith(".html"))
  .map((entry) => ({
    filename: entry.name,
    title: entry.name.replace(/\.html$/i, ""),
  }))
  .sort((a, b) => a.filename.localeCompare(b.filename, "zh-Hans-CN"));
---

<MainGridLayout title="WebPages">
  <div class="card-base px-6 py-6 md:px-8">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
      <div>
        <h1 class="text-3xl font-bold text-90">Web Pages</h1>
        <p class="text-sm text-50 mt-2">
          `public/` 目录下的 HTML 页面会直接从这里访问，登录后可继续编辑、下载和删除。
        </p>
      </div>
      <div class="flex items-center gap-2">
        <a
          href="/login/?next=/webpages/"
          class="btn-plain px-4 py-2 rounded-lg text-sm font-medium"
          data-public-login-btn
        >
          登录编辑
        </a>
        <a
          href="/html-editor/"
          class="btn-regular px-4 py-2 rounded-lg text-sm font-medium hidden"
          data-public-new-btn
        >
          新建
        </a>
      </div>
    </div>

    <div class="space-y-2">
      {htmlEntries.map((item) => (
        <div class="group btn-plain !block w-full rounded-xl px-0 py-0 hover:text-[initial]">
          <div class="flex min-h-16 items-center">
            <div class="w-12 md:w-16 relative flex justify-center self-stretch items-center">
              <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-px bg-[var(--line-divider)]/50"></div>
              <div class="relative z-10 h-2.5 w-2.5 rounded-full bg-[var(--card-bg)] outline outline-4 outline-[var(--card-bg)] border border-[var(--primary)] group-hover:bg-[var(--primary)] transition"></div>
            </div>

            <div class="min-w-0 flex-1 py-3 pr-3">
              <a
                href={`/${item.filename}`}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-base md:text-lg font-bold text-75 group-hover:text-[var(--primary)] transition truncate"
              >
                {item.title}
              </a>
              <div class="text-xs md:text-sm text-50 mt-1 truncate">{item.filename}</div>
            </div>

            <div class="hidden flex shrink-0 items-center gap-2 px-2 md:px-3" data-public-auth-actions>
              <a
                href={`/html-editor/#${encodeURIComponent(item.filename)}`}
                class="btn-regular px-3 py-1.5 rounded-lg text-sm font-medium"
              >
                编辑
              </a>
              <a
                href={`/${item.filename}`}
                download
                class="btn-plain px-3 py-1.5 rounded-lg text-sm font-medium"
              >
                下载
              </a>
              <button
                type="button"
                class="btn-plain px-3 py-1.5 rounded-lg text-sm font-medium !text-red-500"
                data-public-delete-file={item.filename}
              >
                删除
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    import { initializeWebPages } from "../scripts/webpages";
    document.addEventListener("DOMContentLoaded", initializeWebPages);
  </script>
</MainGridLayout>
