---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { friendsConfig } from "@/config";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";

const { nodes, connections } = friendsConfig;
---

<MainGridLayout title={i18n(I18nKey.friends)}>
  <div class="card-base px-6 py-6 md:px-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-90">{i18n(I18nKey.friends)}</h1>
      <p class="text-sm text-50 mt-2">
        拖拽节点可移动，点击头像跳转博客。
      </p>
    </div>
    <div
      id="friend-graph"
      class="w-full h-[720px] relative overflow-hidden rounded-xl bg-[var(--card-bg)]"
    >
      <!-- Edge fade overlays -->
      <div class="pointer-events-none absolute inset-x-0 top-0 h-16" style="background:linear-gradient(to bottom, var(--card-bg), transparent); z-index:3;"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-16" style="background:linear-gradient(to top, var(--card-bg), transparent); z-index:3;"></div>
      <div class="pointer-events-none absolute inset-y-0 left-0 w-16" style="background:linear-gradient(to right, var(--card-bg), transparent); z-index:3;"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-16" style="background:linear-gradient(to left, var(--card-bg), transparent); z-index:3;"></div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/d3@7"></script>
  <script is:inline define:vars={{ nodes, connections }}>
    (function () {
      const container = document.getElementById("friend-graph");
      if (!container || typeof d3 === "undefined") return;

      const width = container.clientWidth;
      const height = container.clientHeight;

      // Assign per-node radius
      for (const d of nodes) {
        d.r = d.id === "Cr" ? 56 : 40;
      }

      // Build link objects
      const linkData = connections.map(([source, target]) => ({
        source,
        target,
      }));

      // SVG for links (underlay)
      const svg = d3
        .select(container)
        .append("svg")
        .attr("width", width)
        .attr("height", height)
        .style("position", "absolute")
        .style("inset", "0")
        .style("z-index", "0");

      const linkGroup = svg.append("g");

      // HTML nodes (overlay)
      const nodeSel = d3
        .select(container)
        .selectAll(".friend-node")
        .data(nodes)
        .join("div")
        .attr("class", "friend-node")
        .style("position", "absolute")
        .style("width", (d) => d.r * 2 + "px")
        .style("transform", "translate(-50%, -50%)")
        .style("cursor", (d) => (d.id === "Cr" ? "default" : "pointer"))
        .style("z-index", (d) => (d.id === "Cr" ? "2" : "1"))
        .style("text-align", "center")
        .style("user-select", "none")
        .html(
          (d) => `
          <div class="friend-avatar-wrapper" style="
            width:${d.r * 2}px;
            height:${d.r * 2}px;
            border-radius:50%;
            overflow:hidden;
            border:2px solid var(--primary);
            display:flex;
            align-items:center;
            justify-content:center;
            background:var(--card-bg);
            ${d.id === "Cr" ? "box-shadow:0 0 18px var(--primary);" : ""}
          ">
            <img
              src="${d.avatar}"
              alt="${d.name}"
              draggable="false"
              style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;"
              onerror="this.style.display='none';const p=this.parentElement;p.textContent='${d.name.charAt(0)}';p.style.color='white';p.style.background='var(--primary)';p.style.fontSize='${d.r}px';p.style.fontWeight='bold';"
            />
          </div>
          <div style="margin-top:8px;font-size:14px;color:var(--text-75);white-space:nowrap;">${d.name}</div>
        `,
        )
        .on("click", (_event, d) => {
          window.open(d.url, "_blank", "noopener,noreferrer");
        });

      // Draw links as paths (shortened to node edge)
      const links = linkGroup
        .selectAll("path.link-line")
        .data(linkData)
        .join("path")
        .attr("class", "link-line")
        .attr("fill", "none")
        .attr("stroke", "var(--primary)")
        .attr("stroke-opacity", 0.4)
        .attr("stroke-width", 1.5);

      // Arrowheads as polygons
      const arrows = linkGroup
        .selectAll("polygon.link-arrow")
        .data(linkData)
        .join("polygon")
        .attr("class", "link-arrow")
        .attr("fill", "var(--primary)")
        .attr("fill-opacity", 0.6);

      function updateLinkGeometry(d) {
        const sx = d.source.x;
        const sy = d.source.y;
        const tx = d.target.x;
        const ty = d.target.y;
        const tr = d.target.r || 32;
        const dx = tx - sx;
        const dy = ty - sy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist === 0) return { d: `M${sx},${sy}L${sx},${sy}`, points: "" };
        const angle = Math.atan2(dy, dx);
        const endX = tx - Math.cos(angle) * tr;
        const endY = ty - Math.sin(angle) * tr;
        const arrowSize = 6;
        const half = Math.PI / 6;
        const ax = endX;
        const ay = endY;
        const p1x = ax - arrowSize * Math.cos(angle - half);
        const p1y = ay - arrowSize * Math.sin(angle - half);
        const p2x = ax - arrowSize * Math.cos(angle + half);
        const p2y = ay - arrowSize * Math.sin(angle + half);
        return {
          d: `M${sx},${sy}L${endX},${endY}`,
          points: `${ax},${ay} ${p1x},${p1y} ${p2x},${p2y}`,
        };
      }

      // Force simulation
      const simulation = d3
        .forceSimulation(nodes)
        .force(
          "link",
          d3.forceLink(linkData).id((d) => d.id).distance(200),
        )
        .force("charge", d3.forceManyBody().strength(-700))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force(
          "collide",
          d3.forceCollide().radius((d) => d.r + 20).strength(0.7),
        );

      // Fix Cr at center
      const crNode = nodes.find((d) => d.id === "Cr");
      if (crNode) {
        crNode.fx = width / 2;
        crNode.fy = height / 2;
      }

      simulation.on("tick", () => {
        links.attr("d", (d) => updateLinkGeometry(d).d);
        arrows.attr("points", (d) => updateLinkGeometry(d).points);

        nodeSel.style("left", (d) => d.x + "px").style("top", (d) => d.y + "px");
      });

      // Drag behavior (skip Cr)
      const drag = d3
        .drag()
        .on("start", (event, d) => {
          if (!event.active) simulation.alphaTarget(0.3).restart();
          d.fx = d.x;
          d.fy = d.y;
        })
        .on("drag", (event, d) => {
          d.fx = event.x;
          d.fy = event.y;
        })
        .on("end", (event, d) => {
          if (!event.active) simulation.alphaTarget(0);
          d.fx = null;
          d.fy = null;
        });

      nodeSel.filter((d) => d.id !== "Cr").call(drag);

      // Resize handler
      const ro = new ResizeObserver((entries) => {
        for (const entry of entries) {
          const w = entry.contentRect.width;
          const h = entry.contentRect.height;
          svg.attr("width", w).attr("height", h);
          simulation.force("center", d3.forceCenter(w / 2, h / 2));
          if (crNode) {
            crNode.fx = w / 2;
            crNode.fy = h / 2;
          }
          simulation.alpha(0.3).restart();
        }
      });
      ro.observe(container);
    })();
  </script>
</MainGridLayout>
