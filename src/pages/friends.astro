---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { friendsConfig } from "@/config";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";

const { nodes, connections } = friendsConfig;
---

<MainGridLayout title={i18n(I18nKey.friends)}>
  <div class="card-base px-6 py-6 md:px-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-90">{i18n(I18nKey.friends)}</h1>
      <p class="text-sm text-50 mt-2">
        拖拽节点可移动，点击头像跳转博客。
      </p>
    </div>
    <div
      id="friend-graph"
      class="w-full h-[600px] relative overflow-hidden rounded-xl bg-[var(--card-bg)] border border-[var(--line-divider)]"
    >
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/d3@7"></script>
  <script is:inline define:vars={{ nodes, connections }}>
    (function () {
      const container = document.getElementById("friend-graph");
      if (!container || typeof d3 === "undefined") return;

      const width = container.clientWidth;
      const height = container.clientHeight;
      const nodeRadius = 32;

      // Build link objects
      const linkData = connections.map(([source, target]) => ({
        source,
        target,
      }));

      // SVG for links (underlay)
      const svg = d3
        .select(container)
        .append("svg")
        .attr("width", width)
        .attr("height", height)
        .style("position", "absolute")
        .style("inset", "0")
        .style("z-index", "0");

      const linkGroup = svg.append("g");

      // HTML nodes (overlay)
      const nodeSel = d3
        .select(container)
        .selectAll(".friend-node")
        .data(nodes)
        .join("div")
        .attr("class", "friend-node")
        .style("position", "absolute")
        .style("width", nodeRadius * 2 + "px")
        .style("transform", "translate(-50%, -50%)")
        .style("cursor", "pointer")
        .style("z-index", "1")
        .style("text-align", "center")
        .style("user-select", "none")
        .html(
          (d) => `
          <div class="friend-avatar-wrapper" style="
            width:${nodeRadius * 2}px;
            height:${nodeRadius * 2}px;
            border-radius:50%;
            overflow:hidden;
            border:2px solid var(--primary);
            display:flex;
            align-items:center;
            justify-content:center;
            background:var(--card-bg);
          ">
            <img
              src="${d.avatar}"
              alt="${d.name}"
              style="width:100%;height:100%;object-fit:cover;display:block;"
              crossorigin="anonymous"
              onerror="this.style.display='none';const p=this.parentElement;p.textContent='${d.name.charAt(0)}';p.style.color='white';p.style.background='var(--primary)';p.style.fontSize='${nodeRadius}px';p.style.fontWeight='bold';"
            />
          </div>
          <div style="margin-top:6px;font-size:12px;color:var(--text-75);white-space:nowrap;">${d.name}</div>
        `,
        )
        .on("click", (_event, d) => {
          window.open(d.url, "_blank", "noopener,noreferrer");
        });

      // Draw links
      const links = linkGroup
        .selectAll("line")
        .data(linkData)
        .join("line")
        .attr("stroke", "var(--primary)")
        .attr("stroke-opacity", 0.4)
        .attr("stroke-width", 1.5);

      // Force simulation
      const simulation = d3
        .forceSimulation(nodes)
        .force(
          "link",
          d3.forceLink(linkData).id((d) => d.id).distance(140),
        )
        .force("charge", d3.forceManyBody().strength(-500))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force(
          "collide",
          d3.forceCollide().radius(nodeRadius + 16).strength(0.7),
        );

      simulation.on("tick", () => {
        links
          .attr("x1", (d) => d.source.x)
          .attr("y1", (d) => d.source.y)
          .attr("x2", (d) => d.target.x)
          .attr("y2", (d) => d.target.y);

        nodeSel.style("left", (d) => d.x + "px").style("top", (d) => d.y + "px");
      });

      // Drag behavior
      const drag = d3
        .drag()
        .on("start", (event, d) => {
          if (!event.active) simulation.alphaTarget(0.3).restart();
          d.fx = d.x;
          d.fy = d.y;
        })
        .on("drag", (event, d) => {
          d.fx = event.x;
          d.fy = event.y;
        })
        .on("end", (event, d) => {
          if (!event.active) simulation.alphaTarget(0);
          d.fx = null;
          d.fy = null;
        });

      nodeSel.call(drag);

      // Resize handler
      const ro = new ResizeObserver((entries) => {
        for (const entry of entries) {
          const w = entry.contentRect.width;
          const h = entry.contentRect.height;
          svg.attr("width", w).attr("height", h);
          simulation.force("center", d3.forceCenter(w / 2, h / 2));
          simulation.alpha(0.3).restart();
        }
      });
      ro.observe(container);
    })();
  </script>
</MainGridLayout>
